{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "node"],
    "baseUrl": ".",
    "noEmit": true,
    "paths": {
      "@/*": ["src/*"],
      "@reqloom/shared": ["../shared/src/index.ts"],
      "@reqloom/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
