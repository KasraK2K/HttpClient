MONGODB_URI=mongodb://httpclient:change-this-app-password@127.0.0.1:27017/restify?authSource=restify
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
DATA_ENCRYPTION_KEY=replace-with-a-different-long-random-secret-at-least-32-characters
SUPERUSER_BOOTSTRAP_SECRET=
COOKIE_NAME=restify_session
COOKIE_DOMAIN=
COOKIE_SECURE=auto
BACKEND_PORT=3500
FRONTEND_ORIGIN=http://127.0.0.1:3030,http://localhost:3030
ALLOW_PRIVATE_NETWORK_TARGETS=true
ALLOWED_OUTBOUND_HOSTS=
