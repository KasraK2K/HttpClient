MONGODB_DATABASE=reqloom
MONGODB_ROOT_USERNAME=root
MONGODB_ROOT_PASSWORD=change-this-root-password
MONGODB_APP_USERNAME=reqloom
MONGODB_APP_PASSWORD=change-this-app-password
MONGODB_URI=mongodb://reqloom:change-this-app-password@127.0.0.1:27017/reqloom?authSource=reqloom
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
DATA_ENCRYPTION_KEY=replace-with-a-different-long-random-secret-at-least-32-characters
SUPERUSER_BOOTSTRAP_SECRET=replace-with-a-one-time-bootstrap-secret
COOKIE_NAME=reqloom_session
COOKIE_DOMAIN=
COOKIE_SECURE=auto
BACKEND_PORT=3500
FRONTEND_ORIGIN=http://127.0.0.1:3030,http://localhost:3030,http://rest.apppair.com
APP_PORT=3500
MONGODB_PORT=27017
MONGODB_BIND_ADDRESS=127.0.0.1
DOCKER_FRONTEND_ORIGIN=http://localhost:3500,http://127.0.0.1:3500,http://rest.apppair.com
DOCKER_MONGODB_BACKUP_URI=mongodb://reqloom:change-this-app-password@127.0.0.1:27017/reqloom?authSource=reqloom
ALLOW_PRIVATE_NETWORK_TARGETS=false
ALLOWED_OUTBOUND_HOSTS=
HISTORY_LIMIT=250
